{
    "name": "qBittorrent Dev Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "timonwong.shellcheck",
                "esbenp.prettier-vscode",
                "redhat.vscode-yaml"
            ]
        }
    },
    "postCreateCommand": "pre-commit install",
    "mounts": [
        "source=${localEnv:HOME}/.local/share/opencode,target=/root/.local/share/opencode,type=bind",
        "source=${localEnv:HOME}/.config/opencode,target=/root/.config/opencode,type=bind"
    ],
    "remoteUser": "root"
}
