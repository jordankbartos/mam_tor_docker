# qBittorrent Docker Configuration

# User and Group ID (run 'id' on your host to find these)
PUID=1000
PGID=1000
TZ=America/Detroit
UMASK=002

# Network Configuration
# Use comma-separated list for multiple subnets (e.g. LAN and VPN client subnet)
LAN_NETWORK=192.168.1.0/24,10.6.0.0/24

# Host paths
# Path to your config directory (e.g., ./config)
CONFIG_PATH=./config
# Path to your downloads directory (e.g., /mnt/data/tor)
DOWNLOADS_PATH=/mnt/data/tor

# WireGuard Configuration
WG_ADDRESS=10.169.232.42/32,fd7d:76ee:e68f:a993:5dad:63a5:aa87:e81/128
WG_PRIVATE_KEY=your_private_key_here
WG_DNS=10.128.0.1, fd7d:76ee:e68f:a993::1
WG_MTU=1320

# WireGuard Peer Configuration
WG_PEER_PUBLIC_KEY=peer_public_key_here
WG_PEER_PRESHARED_KEY=peer_preshared_key_here
WG_PEER_ENDPOINT=ca3.vpn.airdns.org:1637
